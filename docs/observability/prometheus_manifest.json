{
  "schema_version": "1.0",
  "project": "AISEP-Capstone-AI",
  "description": "Prometheus metrics implementation manifest for the AISEP AI backend",
  "library": "prometheus-client>=0.20.0",
  "metrics_endpoint": "/metrics",

  "enabled_modules": ["evaluation", "recommendation", "investor_agent"],

  "priority_order": ["P0", "P1", "P2"],

  "metrics": [
    {
      "name": "aisep_http_requests_total",
      "type": "Counter",
      "labels": ["method", "endpoint", "status_code"],
      "priority": "P0",
      "module": "cross-cutting",
      "description": "Total HTTP requests handled"
    },
    {
      "name": "aisep_http_request_duration_seconds",
      "type": "Histogram",
      "labels": ["method", "endpoint"],
      "buckets": [0.01, 0.05, 0.1, 0.25, 0.5, 1, 2.5, 5, 10],
      "priority": "P0",
      "module": "cross-cutting",
      "description": "HTTP request latency in seconds"
    },
    {
      "name": "aisep_eval_submissions_total",
      "type": "Counter",
      "labels": ["status"],
      "priority": "P0",
      "module": "evaluation",
      "description": "Total evaluation submissions (accepted / error)"
    },
    {
      "name": "aisep_eval_runs_completed_total",
      "type": "Counter",
      "labels": ["terminal_status"],
      "priority": "P0",
      "module": "evaluation",
      "description": "Completed evaluation runs by terminal status"
    },
    {
      "name": "aisep_eval_worker_task_duration_seconds",
      "type": "Histogram",
      "labels": ["terminal_status"],
      "buckets": [1, 5, 10, 30, 60, 120, 300, 600],
      "priority": "P0",
      "module": "evaluation",
      "description": "Celery worker task wall-clock duration"
    },
    {
      "name": "aisep_eval_documents_processed_total",
      "type": "Counter",
      "labels": ["doc_type", "outcome"],
      "priority": "P0",
      "module": "evaluation",
      "description": "Documents processed per type and outcome"
    },
    {
      "name": "aisep_eval_worker_failures_total",
      "type": "Counter",
      "labels": ["error_type"],
      "priority": "P0",
      "module": "evaluation",
      "description": "Worker-level failures by error category"
    },
    {
      "name": "aisep_reco_requests_total",
      "type": "Counter",
      "labels": ["endpoint"],
      "priority": "P0",
      "module": "recommendation",
      "description": "Total recommendation query requests"
    },
    {
      "name": "aisep_reco_request_duration_seconds",
      "type": "Histogram",
      "labels": ["endpoint"],
      "buckets": [0.05, 0.1, 0.25, 0.5, 1, 2.5, 5],
      "priority": "P0",
      "module": "recommendation",
      "description": "Recommendation query latency"
    },
    {
      "name": "aisep_reco_reindex_total",
      "type": "Counter",
      "labels": ["entity_type", "outcome"],
      "priority": "P0",
      "module": "recommendation",
      "description": "Reindex operations by entity type and outcome"
    },
    {
      "name": "aisep_reco_reindex_duration_seconds",
      "type": "Histogram",
      "labels": ["entity_type"],
      "buckets": [0.1, 0.5, 1, 2.5, 5, 10, 30],
      "priority": "P0",
      "module": "recommendation",
      "description": "Reindex operation duration"
    },
    {
      "name": "aisep_agent_stream_requests_total",
      "type": "Counter",
      "labels": ["outcome"],
      "priority": "P0",
      "module": "investor_agent",
      "description": "Total SSE stream sessions by outcome"
    },
    {
      "name": "aisep_agent_stream_duration_seconds",
      "type": "Histogram",
      "labels": [],
      "buckets": [1, 5, 10, 30, 60, 120, 240],
      "priority": "P0",
      "module": "investor_agent",
      "description": "Wall-clock duration of SSE stream sessions"
    },
    {
      "name": "aisep_agent_out_of_scope_total",
      "type": "Counter",
      "labels": [],
      "priority": "P0",
      "module": "investor_agent",
      "description": "Queries rejected by scope guard"
    },
    {
      "name": "aisep_agent_stream_errors_total",
      "type": "Counter",
      "labels": ["error_type"],
      "priority": "P0",
      "module": "investor_agent",
      "description": "Stream errors by type (timeout / internal)"
    },
    {
      "name": "aisep_provider_calls_total",
      "type": "Counter",
      "labels": ["provider", "outcome"],
      "priority": "P1",
      "module": "cross-cutting",
      "description": "External provider API calls"
    },
    {
      "name": "aisep_provider_call_duration_seconds",
      "type": "Histogram",
      "labels": ["provider"],
      "buckets": [0.1, 0.5, 1, 2.5, 5, 10, 30],
      "priority": "P1",
      "module": "cross-cutting",
      "description": "External provider call latency"
    },
    {
      "name": "aisep_provider_retries_total",
      "type": "Counter",
      "labels": ["provider"],
      "priority": "P1",
      "module": "cross-cutting",
      "description": "Provider call retries triggered"
    },
    {
      "name": "aisep_reco_candidate_pool_size",
      "type": "Histogram",
      "labels": [],
      "buckets": [0, 1, 2, 3, 5, 8, 10, 15, 20, 50],
      "priority": "P1",
      "module": "recommendation",
      "description": "Number of candidates returned by vector search"
    },
    {
      "name": "aisep_reco_rerank_applied_total",
      "type": "Counter",
      "labels": ["outcome"],
      "priority": "P1",
      "module": "recommendation",
      "description": "LLM rerank invocations by outcome"
    },
    {
      "name": "aisep_reco_warning_flags_total",
      "type": "Counter",
      "labels": ["flag"],
      "priority": "P1",
      "module": "recommendation",
      "description": "Warning flags raised in recommendation items"
    },
    {
      "name": "aisep_agent_coverage_insufficient_total",
      "type": "Counter",
      "labels": [],
      "priority": "P1",
      "module": "investor_agent",
      "description": "Responses flagged as insufficient coverage"
    },
    {
      "name": "aisep_agent_verified_claims_count",
      "type": "Histogram",
      "labels": [],
      "buckets": [0, 1, 2, 3, 5, 8, 12, 20],
      "priority": "P1",
      "module": "investor_agent",
      "description": "Number of verified claims per response"
    },
    {
      "name": "aisep_agent_references_count",
      "type": "Histogram",
      "labels": [],
      "buckets": [0, 1, 2, 3, 5, 8, 12],
      "priority": "P1",
      "module": "investor_agent",
      "description": "Number of references per response"
    }
  ],

  "files_to_create": [
    {
      "path": "src/shared/observability/__init__.py",
      "priority": "P0",
      "description": "Package init"
    },
    {
      "path": "src/shared/observability/metrics.py",
      "priority": "P0",
      "description": "All Counter / Histogram / Gauge metric objects"
    },
    {
      "path": "src/shared/observability/http_middleware.py",
      "priority": "P0",
      "description": "FastAPI middleware for aisep_http_* metrics"
    },
    {
      "path": "src/shared/observability/provider_tracker.py",
      "priority": "P1",
      "description": "Context manager for external provider call tracking"
    }
  ],

  "files_to_modify": [
    {
      "path": "requirements.txt",
      "priority": "P0",
      "adds": ["prometheus-client>=0.20.0"],
      "description": "Add prometheus-client dependency"
    },
    {
      "path": "src/main.py",
      "priority": "P0",
      "adds": ["mount /metrics ASGI app", "add PrometheusHTTPMiddleware"],
      "metrics": [
        "aisep_http_requests_total",
        "aisep_http_request_duration_seconds"
      ],
      "description": "Wire Prometheus metrics endpoint and HTTP middleware"
    },
    {
      "path": "src/modules/evaluation/api/router.py",
      "priority": "P0",
      "adds": ["counter increment in submit_evaluation_endpoint"],
      "metrics": ["aisep_eval_submissions_total"],
      "description": "Count evaluation submissions"
    },
    {
      "path": "src/modules/evaluation/workers/tasks.py",
      "priority": "P0",
      "adds": ["timer + counters in process_evaluation_run_task"],
      "metrics": [
        "aisep_eval_runs_completed_total",
        "aisep_eval_worker_task_duration_seconds",
        "aisep_eval_documents_processed_total",
        "aisep_eval_worker_failures_total"
      ],
      "description": "Instrument Celery worker task"
    },
    {
      "path": "src/modules/recommendation/api/router.py",
      "priority": "P0",
      "adds": ["timer + counters in 4 endpoint functions"],
      "metrics": [
        "aisep_reco_requests_total",
        "aisep_reco_request_duration_seconds",
        "aisep_reco_reindex_total",
        "aisep_reco_reindex_duration_seconds"
      ],
      "description": "Instrument recommendation API endpoints"
    },
    {
      "path": "src/modules/investor_agent/api/router.py",
      "priority": "P0",
      "adds": ["timer + counters in event_generator"],
      "metrics": [
        "aisep_agent_stream_requests_total",
        "aisep_agent_stream_duration_seconds",
        "aisep_agent_out_of_scope_total",
        "aisep_agent_stream_errors_total"
      ],
      "description": "Instrument SSE stream lifecycle"
    },
    {
      "path": "src/shared/providers/llm/gemini_client.py",
      "priority": "P1",
      "adds": ["track_provider context manager around API calls"],
      "metrics": [
        "aisep_provider_calls_total",
        "aisep_provider_call_duration_seconds",
        "aisep_provider_retries_total"
      ],
      "description": "Track Gemini API calls"
    },
    {
      "path": "src/modules/investor_agent/infrastructure/graph/nodes/search_node.py",
      "priority": "P1",
      "adds": ["track_provider('tavily_search')"],
      "metrics": [
        "aisep_provider_calls_total",
        "aisep_provider_call_duration_seconds"
      ],
      "description": "Track Tavily search calls"
    },
    {
      "path": "src/modules/investor_agent/infrastructure/graph/nodes/extract_node.py",
      "priority": "P1",
      "adds": ["track_provider('tavily_extract')"],
      "metrics": [
        "aisep_provider_calls_total",
        "aisep_provider_call_duration_seconds"
      ],
      "description": "Track Tavily extract calls"
    },
    {
      "path": "src/modules/recommendation/application/services/recommendation_engine.py",
      "priority": "P1",
      "adds": ["candidate pool size observation", "warning flag counter"],
      "metrics": [
        "aisep_reco_candidate_pool_size",
        "aisep_reco_warning_flags_total"
      ],
      "description": "Track recommendation engine internals"
    },
    {
      "path": "src/modules/recommendation/application/services/llm_reranker.py",
      "priority": "P1",
      "adds": ["rerank outcome counter"],
      "metrics": ["aisep_reco_rerank_applied_total"],
      "description": "Track LLM reranker invocations"
    }
  ],

  "cardinality_analysis": {
    "total_estimated_series": "80-120",
    "bounded_labels": true,
    "highest_cardinality_label": "endpoint (≤12 route patterns)",
    "notes": "All labels are bounded enums. No user-supplied or unbounded values."
  },

  "implementation_order": [
    { "step": 1, "action": "pip install prometheus-client", "priority": "P0" },
    {
      "step": 2,
      "action": "Create src/shared/observability/metrics.py with P0 metric objects",
      "priority": "P0"
    },
    {
      "step": 3,
      "action": "Create src/shared/observability/http_middleware.py",
      "priority": "P0"
    },
    {
      "step": 4,
      "action": "Modify src/main.py — mount /metrics + add middleware",
      "priority": "P0"
    },
    {
      "step": 5,
      "action": "Verify: curl localhost:8000/metrics returns default + http metrics",
      "priority": "P0"
    },
    {
      "step": 6,
      "action": "Instrument evaluation router + worker",
      "priority": "P0"
    },
    {
      "step": 7,
      "action": "Instrument recommendation router",
      "priority": "P0"
    },
    {
      "step": 8,
      "action": "Instrument investor agent router",
      "priority": "P0"
    },
    {
      "step": 9,
      "action": "Run full test suite — ensure 220/220 green",
      "priority": "P0"
    },
    {
      "step": 10,
      "action": "Create provider_tracker.py + instrument Gemini, Tavily",
      "priority": "P1"
    },
    {
      "step": 11,
      "action": "Add P1 reco + agent detail metrics",
      "priority": "P1"
    },
    {
      "step": 12,
      "action": "Run full test suite — ensure still green",
      "priority": "P1"
    }
  ],

  "estimated_effort": {
    "P0": "1.5 hours",
    "P0_plus_P1": "2.5 hours",
    "total_lines_added": "~250",
    "total_lines_modified": "~50"
  }
}
